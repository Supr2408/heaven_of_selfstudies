# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/nptel-hub

# Optional persistent uploads directory for production
# Example on Render with a mounted disk: /var/data/uploads
UPLOADS_ROOT_DIR=

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret

# Frontend origin
FRONTEND_URL=http://localhost:3000

# Google sign-in
# Use the same client ID in client/.env.local as NEXT_PUBLIC_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# Development-only demo login fallback
DEMO_USER_EMAIL=demo@nptelhub.com
DEMO_USER_NAME=Demo Learner
